# Copy to .env for local dev. `make dev` reads this file via docker-compose.
# Never commit real secrets — this file holds dev-only placeholder values.

# --- Postgres ---
POSTGRES_DB=relay
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres
# Application roles (created by infra/postgres/init/01-roles.sql)
APP_RW_PASSWORD=app_rw_dev
APP_RO_PASSWORD=app_ro_dev
MIGRATOR_PASSWORD=migrator_dev

# DSNs consumed by apps/api (async runtime uses asyncpg; Alembic uses sync psycopg)
DATABASE_URL=postgresql+asyncpg://app_rw:app_rw_dev@postgres:5432/relay
DATABASE_URL_RO=postgresql+asyncpg://app_ro:app_ro_dev@postgres:5432/relay
MIGRATION_DATABASE_URL=postgresql+psycopg://migrator:migrator_dev@postgres:5432/relay

# --- Redis (two instances: cache/pubsub + celery broker) ---
REDIS_CACHE_URL=redis://redis-cache:6379/0
REDIS_BROKER_URL=redis://redis-broker:6379/0

# --- Object storage (MinIO in dev, S3 in prod) ---
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=relay
S3_SECRET_ACCESS_KEY=relay_dev_secret
S3_BUCKET_ATTACHMENTS=relay-attachments
S3_BUCKET_EXPORTS=relay-exports
S3_BUCKET_EMAIL_INBOUND=relay-email-inbound

# --- SMTP sink (Mailpit in dev, SES in prod) ---
SMTP_HOST=mailpit
SMTP_PORT=1025

# --- Email channel (P0.7) ---
# Transport: smtp (dev → Mailpit), ses (staging/prod), memory (tests).
EMAIL_TRANSPORT=smtp
EMAIL_INBOUND_DOMAIN=inbound.relay.dev
EMAIL_FROM_NAME=Relay
# Dedicated HMAC key for stateless reply tokens — keep separate from JWT_SIGNING_KEY.
EMAIL_REPLY_TOKEN_SECRET=dev-email-reply-token-secret-change-me
# SES (staging/prod). Leave keys unset to use the default AWS credential chain (IAM role).
SES_REGION=us-east-1
# SES_ENDPOINT_URL=
# SES_ACCESS_KEY_ID=
# SES_SECRET_ACCESS_KEY=
# SES_CONFIGURATION_SET=
# Global outbound send-rate cap (token bucket); unset = no cap in dev.
# EMAIL_SEND_RATE_PER_SEC=

# --- App / security ---
ENVIRONMENT=development
LOG_LEVEL=INFO
# 32+ byte secrets; regenerate for any shared environment.
JWT_SIGNING_KEY=dev-only-change-me-please-32-bytes-min
SECRET_ENCRYPTION_KEY=dev-only-change-me-please-32-bytes-min
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000

# --- Google OIDC (optional in dev; leave blank to disable the provider) ---
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
GOOGLE_OIDC_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- Billing / Stripe (test-mode keys only; never a live secret key here) ---
STRIPE_API_BASE=https://api.stripe.com
STRIPE_API_VERSION=2024-06-20
STRIPE_SECRET_KEY=sk_test_dev_placeholder
STRIPE_WEBHOOK_SECRET=whsec_dev_placeholder
STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:3000/billing/success
STRIPE_CHECKOUT_CANCEL_URL=http://localhost:3000/billing/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/settings/billing
BILLING_TRIAL_DAYS=14

# --- Realtime gateway (Centrifugo) ---
# API talks to Centrifugo over the compose-internal address; browsers dial the published host port.
# CENTRIFUGO_TOKEN_SECRET must equal Centrifugo's token_hmac_secret_key (injected into that service).
CENTRIFUGO_API_URL=http://centrifugo:8000
CENTRIFUGO_WS_URL=ws://localhost:8001/connection/websocket
CENTRIFUGO_API_KEY=dev-centrifugo-api-key
CENTRIFUGO_TOKEN_SECRET=dev-centrifugo-token-secret-change-me
# realtime_fallback kill switch: when true, clients may downgrade to long-poll on ws failure.
REALTIME_FALLBACK=true

# --- Knowledge Hub / retrieval (P1.1) ---
# Provider: `deterministic` is the hermetic dev/test/CI embedder (no network, reproducible);
# `openai` is the prod OpenAI-compatible endpoint. A model change is an emb_version bump + re-embed.
EMBEDDING_PROVIDER=deterministic
EMBEDDING_MODEL=relay-hash-v1
EMBEDDING_DIMENSION=1536
EMBEDDING_VERSION=1
# EMBEDDING_API_BASE=https://api.openai.com/v1
# EMBEDDING_API_KEY=
EMBEDDING_BATCH_SIZE=96
# Retrieval (RFC-002 Appendix B): per-arm oversample before RRF, default HNSW recall knob.
RETRIEVAL_DEFAULT_K=8
RETRIEVAL_OVERSAMPLE=40
RETRIEVAL_DEFAULT_EF_SEARCH=100
# External-source sync guards (bounded + timed out).
SOURCE_CRAWL_MAX_PAGES=50
SOURCE_FETCH_TIMEOUT_SECONDS=15

# --- Neko AI orchestrator (P1.2, RFC-003) ---
# Kill switches: AI_GLOBAL_ENABLED is the global on/off; AI_MODEL_ROUTE is the global model-route
# flag (auto | primary | secondary | off).
AI_GLOBAL_ENABLED=true
AI_MODEL_ROUTE=auto
# Provider failover order + creds. "deterministic" is the hermetic dev/test model (no network);
# prod uses e.g. AI_PROVIDER_ORDER=["primary","secondary"] with the HTTP creds below.
AI_PROVIDER_ORDER=["deterministic"]
# AI_PRIMARY_API_BASE=https://api.openai.com/v1
# AI_PRIMARY_API_KEY=
# AI_SECONDARY_API_BASE=
# AI_SECONDARY_API_KEY=
# Model tiering: cheap = preflight/rewrite/verify; frontier = generation.
AI_CHEAP_MODEL=relay-cheap-v1
AI_FRONTIER_MODEL=relay-frontier-v1
AI_PROVIDER_CONCURRENCY=8
AI_BREAKER_THRESHOLD=4
AI_BREAKER_COOLDOWN_SECONDS=15
# Stage timeout budgets (seconds). Preflight is the tight one (≤400 ms).
AI_PREFLIGHT_TIMEOUT_SECONDS=0.4
AI_GENERATE_TIMEOUT_SECONDS=15
AI_VERIFY_TIMEOUT_SECONDS=3
AI_FIRST_TOKEN_TIMEOUT_SECONDS=3
AI_TURN_BUDGET_SECONDS=20
# Retrieval + grounding gate.
AI_RETRIEVAL_K=8
AI_GROUNDING_THRESHOLD_DEFAULT=0.1
AI_ANSWER_MAX_TOKENS=400

# --- Observability (P0.12, RFC-001 §9/§13) ---
# Prometheus metrics: the app serves /metrics; worker/beat/relay/fanout expose METRICS_PORT.
METRICS_ENABLED=true
METRICS_PORT=9100
# OpenTelemetry tracing: OFF unless an OTLP/HTTP endpoint is set (no collector needed in dev).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=relay
OTEL_TRACES_SAMPLER_RATIO=1.0
# Sentry: OFF unless a DSN is set. DEPLOY_SHA is the Sentry release + Prometheus deploy marker.
# SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
DEPLOY_SHA=unknown

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_CENTRIFUGO_WS_URL=ws://localhost:8001/connection/websocket
