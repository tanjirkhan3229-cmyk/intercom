{
  "name": "@relay/widget",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --config vite.loader.config.ts && vite build --config vite.bootstrap.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "esbuild src/rollout.test.ts --bundle --format=esm --platform=node | node --input-type=module",
    "size": "node scripts/check-size.mjs",
    "publish-bundle": "node scripts/publish.mjs"
  },
  "dependencies": {
    "@relay/shared": "*",
    "preact": "^10.24.3"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.9.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
